PORT=8080
# Bearer token required to create/stop sites. Leave empty to disable auth (dev only).
API_KEY=
LOG_LEVEL=info
TZ=UTC
# Default timezone for a site when the create call omits one (scheduling is localized per site).
DEFAULT_TIMEZONE=America/New_York

# --- Cloudflare (Browser Rendering crawl + DNS) ---
CF_ACCOUNT_ID=
CF_API_TOKEN=

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- DigitalOcean (deploy only) ---
DIGITALOCEAN_TOKEN=

# --- Rotating proxy ---
# Option A: single rotating endpoint with geo + sticky sessions (Oxylabs residential, US only):
#   PROXY_SERVER=http://pr.oxylabs.io:7777
#   PROXY_USERNAME=customer-<your-user>      # the rotator appends -cc-US-sessid-<id>-sesstime-<min>
#   PROXY_PASSWORD=secret
#   PROXY_SESSION_PARAM=sessid               # provider's sticky-session keyword
#   PROXY_COUNTRY=US                         # exit country (-cc-US)
#   PROXY_SESSION_MINUTES=3                  # Oxylabs `sesstime`: how long an IP is held
#   PROXY_PER_SESSION=true                   # fresh sticky IP per visit (else time-bucketed)
# Option B: a list of full proxy URLs (one per line or comma separated), rotated by time bucket.
#   PROXY_LIST=http://user:pass@host1:port,http://user:pass@host2:port
PROXY_ENABLED=false
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_LIST=
PROXY_ROTATE_MINUTES=10
PROXY_SESSION_PARAM=
PROXY_COUNTRY=
PROXY_SESSION_MINUTES=0
PROXY_PER_SESSION=false

# --- Simulation behaviour ---
DAILY_VISITS=20
# Visitors/day is randomized per day. Set an explicit range, or leave blank to derive ~±40% of DAILY_VISITS.
DAILY_VISITS_MIN=
DAILY_VISITS_MAX=
CONVERTING_VISITS=5
REFERER_BASE=https://layout.ai
# utm_source defaults to the REFERER_BASE host (override with UTM_SOURCE). REFERRER_CLICK=true enters
# via a real click on the referrer page (coherent Referer + Sec-Fetch-Site) — only when it serves <400.
REFERRER_CLICK=false
APPEND_UTM=true
SUBMIT_FORMS=true
COMPLETE_PAYMENT=false
# Persona email: mode = gmail (raw per-person) | gmail-alias (GMAIL_BASE+tag@gmail.com) | domain (EMAIL_DOMAINS)
EMAIL_MODE=gmail
GMAIL_BASE=
EMAIL_DOMAINS=gmail.com
# Verify addresses upfront: mx (keyless DNS) | abstract | zerobounce | none
EMAIL_VERIFY=mx
EMAIL_VERIFY_API_KEY=
TEST_EMAIL_DOMAIN=gmail.com
MAX_CONCURRENT_VISITS=2
HEADLESS=true
NAV_TIMEOUT_MS=45000
STRATEGY_TTL_HOURS=24
SCHEDULER_ENABLED=true
DATABASE_PATH=./data/simulator.db

# --- Deploy ---
DEPLOY_DOMAIN=service.layout.ai
DEPLOY_REGION=fra1
DEPLOY_SIZE=s-2vcpu-4gb
DEPLOY_IMAGE=ubuntu-24-04-x64
